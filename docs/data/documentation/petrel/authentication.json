{"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"article","identifier":{"url":"doc:\/\/Petrel\/documentation\/Petrel\/Authentication","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"Learn how to authenticate with the AT Protocol using OAuth or legacy authentication methods."}],"hierarchy":{"paths":[["doc:\/\/Petrel\/documentation\/Petrel"]]},"variants":[{"paths":["\/documentation\/petrel\/authentication"],"traits":[{"interfaceLanguage":"swift"}]}],"primaryContentSections":[{"kind":"content","content":[{"type":"heading","level":2,"text":"OAuth Authentication (Recommended)","anchor":"OAuth-Authentication-Recommended"},{"type":"paragraph","inlineContent":[{"type":"text","text":"OAuth is the preferred authentication method for production applications:"}]},{"type":"codeListing","code":["let oauth = OAuthConfig(","    clientId: \"YOUR_CLIENT_ID\",","    redirectUri: \"yourapp:\/\/oauth\/callback\",","    scope: \"atproto app:bsky\"",")","let client = await ATProtoClient(oauthConfig: oauth, namespace: \"com.example.yourapp\")","","\/\/ Start OAuth flow","let authURL = try await client.startOAuthFlow(identifier: \"alice.bsky.social\")","","\/\/ Present authURL, receive callbackURL in your app","try await client.handleOAuthCallback(url: callbackURL)"],"syntax":"swift"},{"type":"heading","level":2,"text":"Legacy Authentication","anchor":"Legacy-Authentication"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Password-based flows are deprecated and not exposed by the public API. Use OAuth for production."}]},{"type":"heading","level":2,"text":"Token Management","anchor":"Token-Management"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Petrel automatically handles token refresh using the "},{"type":"codeVoice","code":"TokenRefreshCoordinator"},{"type":"text","text":". Tokens are securely stored in the keychain and refreshed as needed."}]},{"type":"heading","level":2,"text":"Handling OAuth Callback in your App","anchor":"Handling