{"sections":[],"abstract":[{"text":"Learn how to authenticate with the AT Protocol using OAuth or legacy authentication methods.","type":"text"}],"metadata":{"role":"article","modules":[{"name":"Petrel"}],"title":"Authentication","roleHeading":"Article"},"seeAlsoSections":[{"identifiers":["doc:\/\/Petrel\/documentation\/Petrel\/GettingStarted"],"title":"Getting Started","anchor":"Getting-Started","generated":true}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/petrel\/authentication"]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"hierarchy":{"paths":[["doc:\/\/Petrel\/documentation\/Petrel"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/Petrel\/documentation\/Petrel\/Authentication"},"kind":"article","primaryContentSections":[{"content":[{"level":2,"text":"OAuth Authentication (Recommended)","anchor":"OAuth-Authentication-Recommended","type":"heading"},{"inlineContent":[{"text":"OAuth is the preferred authentication method for production applications:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["let oauth = OAuthConfig(","    clientId: \"YOUR_CLIENT_ID\",","    redirectUri: \"yourapp:\/\/oauth\/callback\",","    scope: \"atproto app:bsky\"",")","let client = await ATProtoClient(oauthConfig: oauth, namespace: \"com.example.yourapp\")","","\/\/ Start OAuth flow","let authURL = try await client.startOAuthFlow(identifier: \"alice.bsky.social\")","","\/\/ Present authURL, receive callbackURL in your app","try await client.handleOAuthCallback(url: callbackURL)"],"type":"codeListing"},{"level":2,"text":"Legacy Authentication","anchor":"Legacy-Authentication","type":"heading"},{"inlineContent":[{"text":"Password-based flows are deprecated and not exposed by the public API. Use OAuth for production.","type":"text"}],"type":"paragraph"},{"level":2,"text":"Token Management","anchor":"Token-Management","type":"heading"},{"inlineContent":[{"text":"Petrel automatically handles token refresh using the ","type":"text"},{"code":"TokenRefreshCoordinator","type":"codeVoice"},{"text":". Tokens are securely stored in the keychain and refreshed as needed.","type":"text"}],"type":"paragraph"},{"level":2,"text":"Handling OAuth Callback in your App","anchor":"Handling-OAuth-Callback-in-your-App","type":"heading"},{"inlineContent":[{"text":"On iOS, forward the redirect URI to the client from your app delegate or SwiftUI scene handler:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["func application(_ app: UIApplication, open url: URL, options: [UIApplication.OpenURLOptionsKey : Any] = [:]) -> Bool {","    Task { try? await client.handleOAuthCallback(url: url) }","    return true","}"],"type":"codeListing"},{"inlineContent":[{"text":"On macOS, use the corresponding NSApplicationDelegate method to pass the URL to ","type":"text"},{"code":"client.handleOAuthCallback(url:)","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"},{"level":2,"text":"Next Steps","anchor":"Next-Steps","type":"heading"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Explore ","type":"text"},{"text":"doc:BasicUsage","type":"text"},{"text":" to start making API calls","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Learn about ","type":"text"},{"text":"doc:TokenManagement","type":"text"},{"text":" for advanced authentication scenarios","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Review ","type":"text"},{"text":"doc:OAuthFlow","type":"text"},{"text":" for detailed OAuth implementation","type":"text"}]}]}],"type":"unorderedList"}],"kind":"content"}],"references":{"doc://Petrel/documentation/Petrel":{"abstract":[{"text":"A comprehensive Swift library for the AT Protocol and Bluesky social network.","type":"text"}],"type":"topic","title":"Petrel","kind":"symbol","identifier":"doc:\/\/Petrel\/documentation\/Petrel","url":"\/documentation\/petrel","role":"collection"},"doc://Petrel/documentation/Petrel/GettingStarted":{"type":"topic","abstract":[{"type":"text","text":"Learn how to integrate Petrel into your Swift project and make your first API calls."}],"url":"\/documentation\/petrel\/gettingstarted","kind":"article","title":"Getting Started","identifier":"doc:\/\/Petrel\/documentation\/Petrel\/GettingStarted","role":"article"}}}