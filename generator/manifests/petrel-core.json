{
  "$comment": "Generation manifest for the public Petrel core package. Paths are relative to the repo root (the directory run.py is invoked from).",
  "package": {
    "kind": "core",
    "name": "Petrel",
    "core_namespace_roots": ["blue"]
  },
  "lexicons": {
    "emit": ["generator/lexicons"],
    "reference": [],
    "exclude_namespaces": ["tools.ozone", "internal.bsky"]
  },
  "swift": {
    "output": "Sources/Petrel/Generated"
  },
  "kotlin": {
    "output": "kotlin/src/main/kotlin/blue/catbird/petrel/generated"
  }
}
