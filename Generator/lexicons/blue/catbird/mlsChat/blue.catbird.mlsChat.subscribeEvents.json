{
  "lexicon": 1,
  "id": "blue.catbird.mlsChat.subscribeEvents",
  "description": "Subscribe to live MLS conversation events via firehose-style streaming",
  "defs": {
    "main": {
      "type": "subscription",
      "description": "Subscribe to live events (messages, reactions, typing, membership changes, group resets, tree changes) via DAG-CBOR framing for conversations involving the authenticated user",
      "parameters": {
        "type": "params",
        "properties": {
          "ticket": {
            "type": "string",
            "description": "Authentication ticket from getSubscriptionTicket."
          },
          "cursor": {
            "type": "string",
            "description": "Opaque resume cursor. If provided, resume after this position."
          },
          "convoIds": {
            "type": "array",
            "description": "Optional conversation filter (only receive events for these conversations).",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "message": {
        "schema": {
          "type": "union",
          "refs": [
            "#messageEvent",
            "#reactionEvent",
            "#typingEvent",
            "#infoEvent",
            "#newDeviceEvent",
            "#groupInfoRefreshRequestedEvent",
            "#readditionRequestedEvent",
            "#membershipChangeEvent",
            "#memberJoined",
            "#memberLeft",
            "#epochAdvanced",
            "#conversationUpdated",
            "#readEvent",
            "#groupResetEvent",
            "#treeChanged"
          ]
        }
      }
    },
    "messageEvent": {
      "type": "object",
      "description": "Event for a newly sent message",
      "required": ["cursor", "message"],
      "properties": {
        "cursor": {
          "type": "string",
          "description": "Resume cursor for this event position"
        },
        "message": {
          "type": "ref",
          "ref": "blue.catbird.mlsChat.defs#messageView"
        },
        "ephemeral": {
          "type": "boolean",
          "description": "True if this is an ephemeral message (not stored, SSE-only)"
        }
      }
    },
    "reactionEvent": {
      "type": "object",
      "description": "Event for a reaction added or removed",
      "required": ["cursor", "convoId", "messageId", "did", "emoji", "reaction", "action"],
      "properties": {
        "cursor": {
          "type": "string",
          "description": "Resume cursor for this event position"
        },
        "convoId": {
          "type": "string",
          "description": "Conversation identifier"
        },
        "messageId": {
          "type": "string",
          "description": "ID of the message that was reacted to"
        },
        "did": {
          "type": "string",
          "format": "did",
          "description": "DID of the user who performed the reaction"
        },
        "emoji": {
          "type": "string",
          "description": "Emoji content of the reaction (alias for reaction)"
        },
        "reaction": {
          "type": "string",
          "description": "Emoji content of the reaction"
        },
        "action": {
          "type": "string",
          "description": "Action performed: 'add' or 'remove'",
          "knownValues": ["add", "remove"]
        }
      }
    },
    "typingEvent": {
      "type": "object",
      "description": "Event indicating a user is typing",
      "required": ["cursor", "convoId", "did", "isTyping"],
      "properties": {
        "cursor": {
          "type": "string",
          "description": "Resume cursor for this event position"
        },
        "convoId": {
          "type": "string",
          "description": "Conversation identifier"
        },
        "did": {
          "type": "string",
          "format": "did",
          "description": "DID of the user typing"
        },
        "isTyping": {
          "type": "boolean",
          "description": "True if the user started typing, false if they stopped"
        }
      }
    },
    "infoEvent": {
      "type": "object",
      "description": "Event carrying informational messages (heartbeat or notices)",
      "required": ["cursor", "info"],
      "properties": {
        "cursor": {
          "type": "string",
          "description": "Resume cursor for this event position"
        },
        "info": {
          "type": "string",
          "description": "Human-readable info or keep-alive message"
        }
      }
    },
    "newDeviceEvent": {
      "type": "object",
      "description": "Event indicating a user has registered a new device that needs to be added to the conversation",
      "required": ["cursor", "convoId", "userDid", "deviceId", "deviceCredentialDid", "pendingAdditionId"],
      "properties": {
        "cursor": {
          "type": "string",
          "description": "Resume cursor for this event position"
        },
        "convoId": {
          "type": "string",
          "description": "Conversation identifier"
        },
        "userDid": {
          "type": "string",
          "format": "did",
          "description": "Base user DID (without device suffix)"
        },
        "deviceId": {
          "type": "string",
          "description": "Device identifier"
        },
        "deviceName": {
          "type": "string",
          "description": "Human-readable device name"
        },
        "deviceCredentialDid": {
          "type": "string",
          "description": "Full device credential DID (format: did:plc:user#device-uuid)"
        },
        "pendingAdditionId": {
          "type": "string",
          "description": "ID of the pending addition record for claim/complete flow"
        }
      }
    },
    "groupInfoRefreshRequestedEvent": {
      "type": "object",
      "description": "Event requesting active members to publish fresh GroupInfo for external commit joins",
      "required": ["cursor", "convoId", "requestedBy", "requestedAt"],
      "properties": {
        "cursor": {
          "type": "string",
          "description": "Resume cursor for this event position"
        },
        "convoId": {
          "type": "string",
          "description": "Conversation identifier"
        },
        "requestedBy": {
          "type": "string",
          "format": "did",
          "description": "DID of the member requesting the refresh"
        },
        "requestedAt": {
          "type": "string",
          "format": "datetime",
          "description": "ISO 8601 timestamp of when the refresh was requested"
        }
      }
    },
    "readditionRequestedEvent": {
      "type": "object",
      "description": "Event indicating a member needs to be re-added to the conversation",
      "required": ["cursor", "convoId", "userDid", "requestedAt"],
      "properties": {
        "cursor": {
          "type": "string",
          "description": "Resume cursor for this event position"
        },
        "convoId": {
          "type": "string",
          "description": "Conversation identifier"
        },
        "userDid": {
          "type": "string",
          "format": "did",
          "description": "DID of the user requesting re-addition"
        },
        "requestedAt": {
          "type": "string",
          "format": "datetime",
          "description": "ISO 8601 timestamp of when re-addition was requested"
        }
      }
    },
    "membershipChangeEvent": {
      "type": "object",
      "description": "Event indicating a member joined, left, or was removed from the conversation",
      "required": ["cursor", "convoId", "did", "action", "epoch"],
      "properties": {
        "cursor": {
          "type": "string",
          "description": "Resume cursor for this event position"
        },
        "convoId": {
          "type": "string",
          "description": "Conversation identifier"
        },
        "did": {
          "type": "string",
          "format": "did",
          "description": "DID of the affected member"
        },
        "action": {
          "type": "string",
          "description": "Action performed",
          "knownValues": ["joined", "left", "removed", "kicked"]
        },
        "actor": {
          "type": "string",
          "format": "did",
          "description": "DID of the actor who performed the action (for removed/kicked)"
        },
        "reason": {
          "type": "string",
          "description": "Optional reason for removal"
        },
        "epoch": {
          "type": "integer",
          "description": "New epoch after this change"
        }
      }
    },
    "readEvent": {
      "type": "object",
      "description": "Event indicating a member has read messages in the conversation",
      "required": ["cursor", "convoId", "did", "readAt"],
      "properties": {
        "cursor": {
          "type": "string",
          "description": "Resume cursor for this event position"
        },
        "convoId": {
          "type": "string",
          "description": "Conversation identifier"
        },
        "did": {
          "type": "string",
          "format": "did",
          "description": "DID of the member who read the messages"
        },
        "messageId": {
          "type": "string",
          "description": "Specific message ID marked as read. If omitted, all messages were marked as read."
        },
        "readAt": {
          "type": "string",
          "format": "datetime",
          "description": "ISO 8601 timestamp of when messages were read"
        }
      }
    },
    "groupResetEvent": {
      "type": "object",
      "description": "Event indicating the MLS group has been reset (new group created to replace the old one)",
      "required": ["cursor", "convoId", "newGroupId", "resetGeneration", "resetBy", "cipherSuite"],
      "properties": {
        "cursor": {
          "type": "string",
          "description": "Resume cursor for this event position"
        },
        "convoId": {
          "type": "string",
          "description": "Conversation identifier"
        },
        "newGroupId": {
          "type": "string",
          "description": "New MLS group ID after reset"
        },
        "resetGeneration": {
          "type": "integer",
          "description": "Monotonically increasing reset generation counter"
        },
        "resetBy": {
          "type": "string",
          "format": "did",
          "description": "DID of the member who initiated the reset"
        },
        "cipherSuite": {
          "type": "string",
          "description": "Cipher suite of the new group"
        },
        "reason": {
          "type": "string",
          "description": "Optional reason for the group reset"
        }
      }
    },
    "treeChanged": {
      "type": "object",
      "description": "Event indicating the MLS ratchet tree has changed (commit processed)",
      "required": ["cursor", "convoId", "confirmationTag", "epoch"],
      "properties": {
        "cursor": {
          "type": "string",
          "description": "Resume cursor for this event position"
        },
        "convoId": {
          "type": "string",
          "description": "Conversation identifier"
        },
        "confirmationTag": {
          "type": "string",
          "description": "Base64 encoded confirmation tag from the commit"
        },
        "epoch": {
          "type": "integer",
          "description": "New epoch after the tree change"
        }
      }
    },
    "memberJoined": {
      "type": "object",
      "description": "Event indicating a member joined the conversation",
      "required": ["cursor", "convoId", "did"],
      "properties": {
        "cursor": {
          "type": "string",
          "description": "Resume cursor for this event position"
        },
        "convoId": {
          "type": "string",
          "description": "Conversation identifier"
        },
        "did": {
          "type": "string",
          "format": "did",
          "description": "DID of the member who joined"
        },
        "epoch": {
          "type": "integer",
          "description": "New epoch after this change"
        }
      }
    },
    "memberLeft": {
      "type": "object",
      "description": "Event indicating a member left or was removed from the conversation",
      "required": ["cursor", "convoId", "did"],
      "properties": {
        "cursor": {
          "type": "string",
          "description": "Resume cursor for this event position"
        },
        "convoId": {
          "type": "string",
          "description": "Conversation identifier"
        },
        "did": {
          "type": "string",
          "format": "did",
          "description": "DID of the member who left"
        },
        "action": {
          "type": "string",
          "description": "Action performed",
          "knownValues": ["left", "removed", "kicked"]
        },
        "actor": {
          "type": "string",
          "format": "did",
          "description": "DID of the actor who performed the removal (for removed/kicked)"
        },
        "reason": {
          "type": "string",
          "description": "Optional reason for removal"
        },
        "epoch": {
          "type": "integer",
          "description": "New epoch after this change"
        }
      }
    },
    "epochAdvanced": {
      "type": "object",
      "description": "Event indicating the MLS epoch has advanced",
      "required": ["cursor", "convoId", "epoch"],
      "properties": {
        "cursor": {
          "type": "string",
          "description": "Resume cursor for this event position"
        },
        "convoId": {
          "type": "string",
          "description": "Conversation identifier"
        },
        "epoch": {
          "type": "integer",
          "description": "New epoch number"
        }
      }
    },
    "conversationUpdated": {
      "type": "object",
      "description": "Event indicating conversation metadata was updated",
      "required": ["cursor", "convoId"],
      "properties": {
        "cursor": {
          "type": "string",
          "description": "Resume cursor for this event position"
        },
        "convoId": {
          "type": "string",
          "description": "Conversation identifier"
        }
      }
    }
  }
}
