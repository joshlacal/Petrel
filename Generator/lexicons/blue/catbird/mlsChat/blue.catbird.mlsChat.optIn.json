{
  "lexicon": 1,
  "id": "blue.catbird.mlsChat.optIn",
  "defs": {
    "main": {
      "type": "procedure",
      "description": "Opt in to MLS chat or query opt-in status for users.",
      "input": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "properties": {
            "deviceId": {
              "type": "string",
              "description": "Device identifier for this opt-in"
            },
            "action": {
              "type": "string",
              "description": "Action to perform",
              "knownValues": ["optIn", "getStatus"]
            },
            "dids": {
              "type": "array",
              "items": {
                "type": "string",
                "format": "did"
              },
              "description": "List of DIDs to check status for (for getStatus action, max 100)",
              "maxLength": 100
            }
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["optedIn", "optedInAt"],
          "properties": {
            "optedIn": {
              "type": "boolean"
            },
            "optedInAt": {
              "type": "string",
              "format": "datetime"
            },
            "statuses": {
              "type": "array",
              "items": {
                "type": "ref",
                "ref": "#optInStatus"
              },
              "description": "Array of opt-in statuses (for getStatus action)"
            },
            "allowFollowersBypass": {
              "type": "boolean",
              "description": "Whether followers can bypass chat request approval"
            },
            "allowFollowingBypass": {
              "type": "boolean",
              "description": "Whether users being followed can bypass chat request approval"
            },
            "autoExpireDays": {
              "type": "integer",
              "description": "Number of days after which unanswered chat requests auto-expire"
            }
          }
        }
      }
    },
    "optInStatus": {
      "type": "object",
      "description": "Opt-in status for a single user",
      "required": ["did", "optedIn"],
      "properties": {
        "did": {
          "type": "string",
          "format": "did",
          "description": "User DID"
        },
        "optedIn": {
          "type": "boolean",
          "description": "Whether user has opted into MLS"
        },
        "optedInAt": {
          "type": "string",
          "format": "datetime",
          "description": "When user opted in (if applicable)"
        }
      }
    }
  }
}
