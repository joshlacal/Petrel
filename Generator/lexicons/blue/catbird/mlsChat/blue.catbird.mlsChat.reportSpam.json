{
  "lexicon": 1,
  "id": "blue.catbird.mlsChat.reportSpam",
  "defs": {
    "main": {
      "type": "procedure",
      "description": "Report a conversation member for spam",
      "input": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["convoId", "reportedDid"],
          "properties": {
            "convoId": {
              "type": "string",
              "description": "Conversation identifier"
            },
            "reportedDid": {
              "type": "string",
              "format": "did",
              "description": "DID of the member being reported for spam"
            },
            "reason": {
              "type": "string",
              "description": "Optional reason for the report",
              "maxLength": 1024
            }
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["id", "createdAt"],
          "properties": {
            "id": {
              "type": "string",
              "description": "Unique identifier for the spam report"
            },
            "createdAt": {
              "type": "string",
              "format": "datetime",
              "description": "When the report was created"
            }
          }
        }
      },
      "errors": [
        {
          "name": "Unauthorized",
          "description": "Authentication required"
        },
        {
          "name": "NotFound",
          "description": "Conversation or member not found"
        },
        {
          "name": "DuplicateReport",
          "description": "A report for this member in this conversation already exists"
        }
      ]
    }
  }
}
