{
  "lexicon": 1,
  "id": "blue.catbird.mlsChat.blocks",
  "defs": {
    "main": {
      "type": "procedure",
      "description": "Manage block relationships for MLS conversations. Supports checking block status, querying blocks between DIDs, and handling block changes.",
      "input": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["action"],
          "properties": {
            "action": {
              "type": "string",
              "description": "Block action to perform",
              "knownValues": ["getStatus", "check", "handleChange"]
            },
            "convoId": {
              "type": "string",
              "description": "Conversation identifier (for getStatus action)"
            },
            "dids": {
              "type": "array",
              "description": "DIDs to check for block relationships (for check action, 2-100 DIDs)",
              "items": {
                "type": "string"
              },
              "minItems": 2,
              "maxItems": 100
            },
            "blockRecord": {
              "type": "ref",
              "ref": "#blockRecord",
              "description": "Block record for handleChange action"
            }
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "properties": {
            "hasConflicts": {
              "type": "boolean",
              "description": "Whether any block conflicts were found"
            },
            "blocks": {
              "type": "array",
              "description": "Block relationships found",
              "items": {
                "type": "ref",
                "ref": "#blockRelationship"
              }
            },
            "checkedAt": {
              "type": "string",
              "format": "datetime",
              "description": "When the check was performed"
            },
            "status": {
              "type": "ref",
              "ref": "#conversationBlockStatus",
              "description": "Block status for a specific conversation"
            },
            "changes": {
              "type": "array",
              "description": "Results of block change processing",
              "items": {
                "type": "ref",
                "ref": "#blockChangeResult"
              }
            }
          }
        }
      },
      "errors": [
        {
          "name": "InvalidRequest",
          "description": "Invalid request parameters"
        },
        {
          "name": "Unauthorized",
          "description": "Authentication required"
        }
      ]
    },
    "blockRecord": {
      "type": "object",
      "description": "A block record change to process",
      "required": ["blockerDid", "blockedDid", "action"],
      "properties": {
        "blockerDid": {
          "type": "string",
          "format": "did",
          "description": "DID of the user who created/deleted the block"
        },
        "blockedDid": {
          "type": "string",
          "format": "did",
          "description": "DID of the user being blocked/unblocked"
        },
        "action": {
          "type": "string",
          "description": "Whether the block was created or deleted",
          "knownValues": ["created", "deleted"]
        }
      }
    },
    "blockRelationship": {
      "type": "object",
      "description": "A block relationship between two users",
      "required": ["blockerDid", "blockedDid", "createdAt"],
      "properties": {
        "blockerDid": {
          "type": "string",
          "format": "did",
          "description": "DID of the blocking user"
        },
        "blockedDid": {
          "type": "string",
          "format": "did",
          "description": "DID of the blocked user"
        },
        "createdAt": {
          "type": "string",
          "format": "datetime",
          "description": "When the block was created"
        },
        "blockUri": {
          "type": "string",
          "description": "AT URI of the block record"
        }
      }
    },
    "conversationBlockStatus": {
      "type": "object",
      "description": "Block status for a specific conversation",
      "required": ["convoId", "hasConflicts", "memberCount"],
      "properties": {
        "convoId": {
          "type": "string",
          "description": "Conversation identifier"
        },
        "hasConflicts": {
          "type": "boolean",
          "description": "Whether there are block conflicts in this conversation"
        },
        "memberCount": {
          "type": "integer",
          "description": "Number of members in the conversation"
        },
        "checkedAt": {
          "type": "string",
          "format": "datetime",
          "description": "When the status was last checked"
        }
      }
    },
    "blockChangeResult": {
      "type": "object",
      "description": "Result of processing a block change for a conversation",
      "required": ["convoId", "action"],
      "properties": {
        "convoId": {
          "type": "string",
          "description": "Affected conversation identifier"
        },
        "action": {
          "type": "string",
          "description": "Action taken",
          "knownValues": ["block_detected", "block_removed"]
        },
        "removedDid": {
          "type": "string",
          "format": "did",
          "description": "DID of the member removed due to block conflict"
        }
      }
    }
  }
}
